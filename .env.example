OPENAI_API_KEY=

KRAKEN_API_KEY=
KRAKEN_API_SECRET=
KRAKEN_SANDBOX=true
KRAKEN_OAUTH_CLIENT_ID=
KRAKEN_OAUTH_CLIENT_SECRET=
KRAKEN_OAUTH_AUTH_URL=
KRAKEN_OAUTH_TOKEN_URL=
KRAKEN_OAUTH_REDIRECT_URI=http://localhost:8000/api/connections/kraken/oauth/callback
KRAKEN_OAUTH_SCOPE=balance openpositions
POLL_INTERVAL_SECONDS=300

ALBY_CLIENT_ID=
ALBY_CLIENT_SECRET=
ALBY_REDIRECT_URI=http://localhost:3000/connections/lightning/callback
ALBY_AGENT_WALLET_ADDRESS=leantrade-agent@getalby.local
ALBY_AGENT_BALANCE_SATS=0

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
JWT_SECRET=

# ── Asset platform (Supabase Postgres) ───────────────────────────────────────
# Leave blank to use local SQLite (data/assets.db) — fine for development.
# For production set to your Supabase connection string:
#   postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
SUPABASE_DB_URL=
APP_ENV=development
ENABLE_ASSET_SCHEDULER=true
ASSET_WARM_STARTUP_REFRESH=true
ASSET_REFRESH_PRODUCTION_ONLY=false
ADMIN_SECRET=
ADMIN_API_SECRET=
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

# ── Frontend runtime ─────────────────────────────────────────────────────────
# development: local app shows all build/test/development workflow sections.
# production: / stays the landing page; /home shows the limited production app.
VITE_APP_EXPERIENCE=development
VITE_APP_HOME_PATH=/home
VITE_ENABLE_DEVELOPMENT_FEATURES=true
VITE_ENABLE_ADMIN=false
VITE_WAITLIST_ENDPOINT=
